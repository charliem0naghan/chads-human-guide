---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');

  return allNotes.map(note => ({
    params: { slug: note.slug },
    props: {
      note,
      categoryNotes: allNotes.filter(
        n => n.data.categorySlug === note.data.categorySlug
      ),
    },
  }));
}

const { note, categoryNotes } = Astro.props;
const { Content } = await note.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Search index (all non-root notes)
const allNotes = await getCollection('notes');
const searchIndex = allNotes
  .filter(n => n.data.categorySlug !== 'root')
  .map(n => ({ title: n.data.title, slug: n.slug, category: n.data.category, categorySlug: n.data.categorySlug }));
const searchIndexJson = JSON.stringify(searchIndex);

const displayCatName = note.data.category.replace(/^\d+ - /, '');
---

<Layout title={note.data.title} searchIndexJson={searchIndexJson}>
  <div class="note-layout">

    <Sidebar
      currentSlug={note.slug}
      categorySlug={note.data.categorySlug}
      categoryName={note.data.category}
      notes={categoryNotes}
    />

    <main class="note-main">
      <nav class="note-breadcrumb" aria-label="breadcrumb">
        <a href={`${base}/`}>Home</a>
        <span class="sep">/</span>
        {note.data.categorySlug !== 'root' && (
          <>
            <a href={`${base}/category/${note.data.categorySlug}`}>{displayCatName}</a>
            <span class="sep">/</span>
          </>
        )}
        {note.data.subcategory && (
          <>
            <span>{note.data.subcategory}</span>
            <span class="sep">/</span>
          </>
        )}
        <span>{note.data.title}</span>
      </nav>

      <article class="note-content">
        <Content />
      </article>
    </main>

  </div>
</Layout>
